<!DOCTYPE html>
<html lang="en">    
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{.Title}}</title>
</head>
<body>
{{if ge .FinalValue 80}}
    <h1>Good</h1>
{{else if ge .FinalValue 60}}
    <h2>Nice Try</h2>
{{else}}
    <h3>Try Again</h3>
{{end}}
</body>
</html>
{{/* // This is the comparator.gohtml file, which contains a template that uses conditional statements to compare a value and display different messages based on the comparison results.
// eq : ==
// ne : !=
// lt : <
// le : <=
// gt : >
// ge : >= */}}