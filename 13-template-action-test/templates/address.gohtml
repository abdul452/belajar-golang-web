<!DOCTYPE html>
<html lang="en">    
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{.Title}}</title>
</head>
<body>
{{/* Contoh Komentar */}}
<h1>Name : {{.Name}}</h1>
{{with .Address}}
<h2>Address</h2>
<p>Street : {{.Street}}</p>
<p>City : {{.City}}</p>
{{else}}
<h2>Address Not Found</h2>
{{end}}
</body>
</html>